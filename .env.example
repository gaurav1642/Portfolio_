# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# MONGODB_URI: Optional MongoDB database connection string. If omitted,
# the server automatically falls back to a durable local JSON database file.
MONGODB_URI=

# Admin Dashboard Password (Default: adminpassword123)
ADMIN_PASSWORD=

# Admin Dashboard Username (Default: admin)
ADMIN_USERNAME=

# Secret token signing key
JWT_SECRET=

# SMTP Email Configuration for sending replies directly to users
# Configure these in your AI Studio secrets to enable actual email delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
